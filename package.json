{
  "name": "kensaku",
  "version": "0.3.1",
  "description": "CLI to pin GitHub Actions uses references to commit SHAs.",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/koji/kensaku"
  },
  "homepage": "https://github.com/koji/kensaku",
  "bugs": {
    "url": "https://github.com/koji/kensaku/issues"
  },
  "license": "MIT",
  "type": "module",
  "keywords": [
    "kensaku",
    "search",
    "sha",
    "github",
    "github-actions"
  ],
  "bin": {
    "kensaku": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_JA.md"
  ],
  "exports": {
    ".": "./dist/lib.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "node ./dist/cli.js check",
    "fix": "node ./dist/cli.js fix",
    "prepack": "npm run build && npm test",
    "test": "node --experimental-strip-types --test test/**/*.test.ts",
    "test:dist": "node --test test-dist/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
